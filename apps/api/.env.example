DATABASE_URL=postgresql://postgres:password@localhost:5432/ridelogger
JWT_SECRET=dev-secret-change-in-production
ORS_API_KEY=your-ors-api-key
FRONTEND_URL=http://localhost:3000
PORT=4000
NODE_ENV=development

# Production SSM parameter paths (set on Lambda via infrastructure.yml — do not set locally)
# DB_HOST_PARAM=/ridelogger/production/db-host
# DB_NAME_PARAM=/ridelogger/production/db-name
# DB_PASS_PARAM=/ridelogger/production/db-password
# DB_PORT_PARAM=/ridelogger/production/db-port
# DB_URI_PARAM=/ridelogger/production/db-uri
# DB_USER_PARAM=/ridelogger/production/db-user
